# Autonomous AI Developer System - Environment Configuration

# GitHub Configuration
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO_PATH=.
GITHUB_REMOTE=origin

# AI Model Configuration
# Set your preferred LLM provider
LLM_PROVIDER=openai
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4

# Streamlit Configuration
STREAMLIT_THEME_PRIMARYCOLOR=#FF6B35
STREAMLIT_THEME_BACKGROUNDCOLOR=#FFFFFF
STREAMLIT_LOGGER_LEVEL=info

# System Configuration
DEBUG_MODE=false
LOG_LEVEL=INFO
APPROVAL_REQUIRED=true
AUTO_PUSH=false

# Code Quality Thresholds
MIN_CODE_QUALITY_SCORE=70
MIN_TEST_COVERAGE=80
STRICT_VALIDATION=false

# Feature Flags
ENABLE_AUTO_COMMIT=false
ENABLE_PULL_REQUEST_CREATION=false
ENABLE_CODE_FORMATTING=true
ENABLE_SECURITY_CHECKS=true
